										"body": {
											"mode": "raw",
											"raw": "{\n  \"delivery_city_id\": \"{{city_id}}\",\n  \"delivery_address\": \"Cotonou, St Michel\",\n  \"specific_information\": \"Maison bleue\"\n}",
											"options": {"raw": {"language": "json"}}
										},
										"url": {"raw": "{{base_url}}/shop/v2/cart/{{client_id}}/checkout/", "host": ["{{base_url}}"], "path": ["shop", "v2", "cart", "{{client_id}}", "checkout", ""]},
										"description": "Checkout avec support des variantes. Le prix utilisé est celui de la variante si elle en a un, sinon celui du produit."
									}
								}
							]
